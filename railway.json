{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn api_server:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "env": {
    "DASHSCOPE_API_KEY": {
      "value": ""
    },
    "OPENWEATHER_API_KEY": {
      "value": ""
    },
    "AMAP_API_KEY": {
      "value": ""
    }
  }
}
